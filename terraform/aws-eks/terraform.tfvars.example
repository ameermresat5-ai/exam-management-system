# Example values only. Do not commit real secrets.
project_name = "exam-management-system"
environment  = "demo"
aws_region   = "us-east-1"

vpc_cidr             = "10.20.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs  = ["10.20.1.0/24", "10.20.2.0/24"]
private_subnet_cidrs = ["10.20.101.0/24", "10.20.102.0/24"]

cluster_version     = "1.29"
node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 3

db_name              = "exam_management"
db_username          = "exam_user"
db_password          = "CHANGE_ME_EXAMPLE_ONLY"
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20